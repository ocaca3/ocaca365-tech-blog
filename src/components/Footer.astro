                >
            </a>
            <a href="https://x.com/komuin_engineer" target="_blank" rel="noopener" aria-label="X">
                <svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"
                    ><path fill="currentColor" d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"></path></svg
                >
            </a>
            <a href="/rss.xml" aria-label="RSS">
                <svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"
                    ><path fill="currentColor" d="M2.5 12a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zM0 8.5a.5.5 0 0 1 .5-.5C4.642 8 8 11.358 8 15.5a.5.5 0 0 1-1 0A6.5 6.5 0 0 0 .5 9a.5.5 0 0 1-.5-.5zm0-4A.5.5 0 0 1 .5 4a11.5 11.5 0 0 1 11.5 11.5.5.5 0 0 1-1 0A10.5 10.5 0 0 0 .5 5a.5.5 0 0 1-.5-.5z"></path></svg
                >
            </a>
        </div>
    </div>
</footer>

<style>
    footer {
        background: var(--oc-bg-elevated);
        border-top: 1px solid var(--oc-border);
        padding: 2.5em 2em;
        color: var(--oc-text-faint);
        font-size: 13px;
    }
    .footer-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1em;
    }
    .copyright {
        text-align: center;
    }
    .social-links {
        display: flex;
        gap: 1.2em;
    }
    .social-links a {
        display: flex;
        text-decoration: none;
        color: var(--oc-text);
        opacity: 0.6;
        transition: opacity 0.2s, color 0.2s;
    }
    .social-links a:hover {
        opacity: 1;
        color: var(--oc-accent-dark);
    }
    @media (max-width: 720px) {
        footer { padding: 2em 1em; }
    }
</style>