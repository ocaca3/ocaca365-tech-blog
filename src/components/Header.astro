---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
		<div class="social-links">
			<a href="https://github.com/ocaca3" target="_blank" rel="noopener">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href="https://x.com/komuin_engineer" target="_blank" rel="noopener" aria-label="X">
				<svg viewBox="0 0 16 16" aria-hidden="true" width="18" height="18"
					><path
						fill="currentColor"
						d="M12.6.75h2.454l-5.36 6.142L16 15.25h-4.937l-3.867-5.07-4.425 5.07H.316l5.733-6.57L0 .75h5.063l3.495 4.633L12.601.75Zm-.86 13.028h1.36L4.323 2.145H2.865l8.875 11.633Z"
					></path></svg
				>
			</a>
			<a href="/rss.xml">
				<span class="sr-only">RSS</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="20" height="20"
					><path
						fill="currentColor"
						d="M2.5 12a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3zM0 8.5a.5.5 0 0 1 .5-.5C4.642 8 8 11.358 8 15.5a.5.5 0 0 1-1 0A6.5 6.5 0 0 0 .5 9a.5.5 0 0 1-.5-.5zm0-4A.5.5 0 0 1 .5 4a11.5 11.5 0 0 1 11.5 11.5.5.5 0 0 1-1 0A10.5 10.5 0 0 0 .5 5a.5.5 0 0 1-.5-.5z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 0 2em;
		background: var(--oc-bg-elevated);
		border-bottom: 1px solid var(--oc-border);
		box-shadow: none;
	}
	h2 {
		margin: 0;
		font-family: 'Fraunces', Georgia, serif;
		font-size: 20px;
		font-weight: 500;
		letter-spacing: -0.02em;
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
		color: var(--oc-text);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1100px;
		margin: 0 auto;
	}
	nav a {
		padding: 1.2em 0.8em;
		color: var(--oc-text);
		opacity: 0.7;
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 14px;
		transition: opacity 0.2s, border-color 0.2s;
	}
	nav a:hover {
		opacity: 1;
	}
	nav a.active {
		opacity: 1;
		border-bottom-color: var(--oc-accent);
	}
	.social-links {
		display: flex;
		gap: 0.5em;
	}
	.social-links a {
		display: flex;
		align-items: center;
		padding: 1.2em 0.5em;
		opacity: 0.6;
	}
	.social-links a:hover {
		opacity: 1;
		color: var(--oc-accent-dark);
	}
	@media (max-width: 720px) {
		header { padding: 0 1em; }
		.internal-links { display: flex; }
		nav a { padding: 1em 0.4em; font-size: 13px; }
	}
</style>