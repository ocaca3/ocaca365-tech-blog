---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props as Props & { tags?: string[] };
---

<html lang="ja">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main class="oc-post-main">
      <article>
        <header class="oc-post-header">
          <div class="oc-post-meta">
            <FormattedDate date={pubDate} />
            {updatedDate && (
              <span class="oc-post-updated">
                · Last updated <FormattedDate date={updatedDate} />
              </span>
            )}
          </div>
          <h1 class="oc-post-title">{title}</h1>
          {description && <p class="oc-post-description">{description}</p>}
          {tags && tags.length > 0 && (
            <div class="oc-post-tags">
              {tags.map((t) => (
                <span class="oc-post-tag">{t}</span>
              ))}
            </div>
          )}
        </header>

        {heroImage && (
          <div class="oc-post-hero">
            <Image width={1020} height={510} src={heroImage} alt="" />
          </div>
        )}

        <div class="oc-post-prose">
          <slot />
        </div>

        <footer class="oc-post-footer">
          <a href="/blog/" class="oc-post-back">← All articles</a>
        </footer>
      </article>
    </main>
    <Footer />

    <style is:global>
      /* 本文のグローバルスタイル(Markdown生要素に効かせる) */
      .oc-post-prose {
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 17px;
        line-height: 1.8;
        color: var(--oc-text);
      }
      .oc-post-prose h2 {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 400;
        font-size: 28px;
        letter-spacing: -0.02em;
        margin: 2.5em 0 0.8em;
        line-height: 1.3;
      }
      .oc-post-prose h3 {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 400;
        font-size: 22px;
        letter-spacing: -0.01em;
        margin: 2em 0 0.6em;
        line-height: 1.3;
      }
      .oc-post-prose p {
        margin: 0 0 1.5em;
      }
      .oc-post-prose a {
        color: var(--oc-accent-dark);
        text-decoration: underline;
        text-decoration-color: var(--oc-accent);
        text-underline-offset: 3px;
      }
      .oc-post-prose a:hover {
        color: var(--oc-text);
      }
      .oc-post-prose ul,
      .oc-post-prose ol {
        margin: 0 0 1.5em;
        padding-left: 1.5em;
      }
      .oc-post-prose li {
        margin: 0.3em 0;
      }
      .oc-post-prose blockquote {
        border-left: 3px solid var(--oc-accent);
        padding: 0.5em 1.2em;
        margin: 1.5em 0;
        color: var(--oc-text-muted);
        font-style: normal;
        background: var(--oc-bg-elevated);
      }
      .oc-post-prose code {
        font-family: ui-monospace, 'SF Mono', Consolas, monospace;
        font-size: 0.9em;
        background: var(--oc-bg-elevated);
        padding: 2px 6px;
        border-radius: 3px;
      }
      .oc-post-prose pre {
        background: #1a1915;
        color: #f1ede0;
        padding: 1.2em 1.4em;
        border-radius: 6px;
        overflow-x: auto;
        margin: 1.5em 0;
        font-size: 14px;
        line-height: 1.6;
      }
      .oc-post-prose pre code {
        background: transparent;
        padding: 0;
        color: inherit;
        font-size: inherit;
      }
      .oc-post-prose img {
        max-width: 100%;
        height: auto;
        border-radius: 6px;
        margin: 1.5em 0;
      }
      .oc-post-prose hr {
        border: none;
        border-top: 1px solid var(--oc-border);
        margin: 2.5em 0;
      }
      .oc-post-prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 1.5em 0;
        font-size: 14px;
      }
      .oc-post-prose th,
      .oc-post-prose td {
        padding: 0.6em 0.8em;
        border-bottom: 1px solid var(--oc-border);
        text-align: left;
      }
      .oc-post-prose th {
        font-weight: 500;
        color: var(--oc-text-faint);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }
    </style>

    <style>
      .oc-post-main {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 24px;
        width: 100%;
        box-sizing: border-box;
        font-family: 'Inter', system-ui, sans-serif;
        color: var(--oc-text);
      }
      .oc-post-header {
        padding: 80px 0 40px;
      }
      .oc-post-meta {
        font-size: 13px;
        color: var(--oc-text-faint);
        margin-bottom: 16px;
        font-variant-numeric: tabular-nums;
      }
      .oc-post-updated {
        margin-left: 4px;
      }
      .oc-post-title {
        font-family: 'Fraunces', Georgia, serif;
        font-weight: 300;
        font-size: clamp(32px, 5vw, 48px);
        line-height: 1.15;
        letter-spacing: -0.025em;
        margin: 0 0 20px;
        color: var(--oc-text);
      }
      .oc-post-description {
        font-size: 18px;
        color: var(--oc-text-muted);
        line-height: 1.6;
        margin: 0 0 24px;
      }
      .oc-post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }
      .oc-post-tag {
        font-size: 12px;
        color: var(--oc-accent-dark);
        background: rgba(124, 198, 42, 0.1);
        padding: 4px 10px;
        border-radius: 3px;
      }
      .oc-post-hero {
        margin: 0 0 40px;
      }
      .oc-post-hero :global(img) {
        width: 100%;
        height: auto;
        border-radius: 6px;
        display: block;
      }
      .oc-post-footer {
        margin: 80px 0 40px;
        padding-top: 32px;
        border-top: 1px solid var(--oc-border);
      }
      .oc-post-back {
        font-size: 14px;
        color: var(--oc-text-muted);
        text-decoration: none;
        border-bottom: 1px solid transparent;
        transition: border-color 0.2s, color 0.2s;
      }
      .oc-post-back:hover {
        color: var(--oc-text);
        border-bottom-color: var(--oc-accent);
      }

      @media (max-width: 720px) {
        .oc-post-header {
          padding: 48px 0 24px;
        }
        .oc-post-description {
          font-size: 16px;
        }
        .oc-post-footer {
          margin: 56px 0 32px;
        }
      }
    </style>
  </body>
</html>